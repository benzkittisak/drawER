# Development image (hot reload). Bun installs deps; Node (bundled in the image) runs the sync server.
# Source is bind-mounted at runtime (docker-compose.dev.yml); node_modules stays in an anonymous volume.
# Used for BOTH services: web runs `bun run dev` (Vite HMR), sync runs nodemon → node.
FROM oven/bun:1.3.13-alpine
WORKDIR /app
COPY package.json bun.lock ./
# --ignore-scripts: better-sqlite3/oracledb have no Bun/musl prebuilds and would fall back to
# node-gyp (needs python + toolchain, slow). Web never uses them; sync only needs them for the
# optional SQLite/Oracle import, which it loads lazily. Keeps the image build fast and reliable.
RUN bun install --frozen-lockfile --ignore-scripts
EXPOSE 5173 1234
CMD ["bun", "run", "dev", "--", "--host"]
