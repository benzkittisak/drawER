# Development image (hot reload). Node 24 (sync server) + Bun (package manager). Installs deps
# with Bun; source is bind-mounted at runtime
# (docker-compose.dev.yml) while node_modules stays in an anonymous volume.
# Used for BOTH services: web runs `bun run dev` (Vite HMR), sync runs nodemon → node.
FROM node:24-alpine
RUN npm i -g bun
WORKDIR /app
COPY package.json bun.lock ./
RUN bun install --frozen-lockfile
EXPOSE 5173 1234
CMD ["bun", "run", "dev", "--", "--host"]
